{
  "info": {
    "name": "SecureWallet API",
    "description": "Colección de endpoints para SecureWallet - Examen Final INF781",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "ticket",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (RF-01)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"ci\": \"99999999\",\n  \"email\": \"test@test.com\",\n  \"phone\": \"70999999\",\n  \"password\": \"Test1234!@\",\n  \"captcha_token\": \"test-captcha\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login (RF-02) - Juan Perez",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "  pm.collectionVariables.set('token', jsonData.access_token);",
                  "  pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
                  "}",
                  "if (jsonData.ticket) {",
                  "  pm.collectionVariables.set('ticket', jsonData.ticket);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"User1234!@\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@securewallet.com\",\n  \"password\": \"Admin123!@#\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login - Maria Lopez",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria@test.com\",\n  \"password\": \"User1234!@\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token (RS-07)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout (RF-10)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Enable MFA (RF-03)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/mfa/enable",
              "host": ["{{base_url}}"],
              "path": ["auth", "mfa", "enable"]
            }
          }
        },
        {
          "name": "MFA Verify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket\": \"{{ticket}}\",\n  \"totp_code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/mfa/verify",
              "host": ["{{base_url}}"],
              "path": ["auth", "mfa", "verify"]
            }
          }
        }
      ]
    },
    {
      "name": "Profile & Wallet",
      "item": [
        {
          "name": "Get Profile (RF-04)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            }
          }
        },
        {
          "name": "Get Balance (RF-04)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet",
              "host": ["{{base_url}}"],
              "path": ["wallet"]
            }
          }
        },
        {
          "name": "Top Up (RF-05)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/wallet/topup",
              "host": ["{{base_url}}"],
              "path": ["wallet", "topup"]
            }
          }
        }
      ]
    },
    {
      "name": "Transfers",
      "item": [
        {
          "name": "Create Transfer (RF-06)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": \"maria@test.com\",\n  \"monto\": 100.00,\n  \"descripcion\": \"Pago prueba\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            }
          }
        },
        {
          "name": "Confirm Transfer (RF-07)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/transfers/REEMPLAZAR_CON_UUID/confirm",
              "host": ["{{base_url}}"],
              "path": ["transfers", "REEMPLAZAR_CON_UUID", "confirm"]
            }
          }
        },
        {
          "name": "Create Transfer +500 (TOTP Required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": \"maria@test.com\",\n  \"monto\": 600.00,\n  \"descripcion\": \"Pago grande\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Get History (RF-08)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transactions?page=1",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Get History - Filtered by type (RF-08)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transactions?page=1&type=topup",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "type", "value": "topup" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (RF-09)",
      "item": [
        {
          "name": "List Users (Admin only)",

          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            }
          }
        },
        {
          "name": "Block/Unblock User (Admin only)",

          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/REEMPLAZAR_CON_UUID/block",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "REEMPLAZAR_CON_UUID", "block"]
            }
          }
        },
        {
          "name": "Audit Logs (Admin only)",

          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/audit-logs?page=1",
              "host": ["{{base_url}}"],
              "path": ["admin", "audit-logs"],
              "query": [
                { "key": "page", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "PRUEBAS DE SEGURIDAD (ATAQUES)",
      "item": [
        {
          "name": "[RS-01] IDOR - Access other user data",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet",
              "host": ["{{base_url}}"],
              "path": ["wallet"]
            },
            "description": "El endpoint /wallet siempre devuelve los datos del usuario autenticado. No se puede acceder a datos de otro usuario aunque se intente manipular la URL."
          }
        },
        {
          "name": "[RS-02] RBAC - User tries Admin endpoint",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            },
            "description": "Con token de usuario normal (USER), debe responder 403 Forbidden"
          }
        },
        {
          "name": "[RS-05] Idempotency - Double charge test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "TEST-DOUBLE-CHARGE-KEY" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": \"maria@test.com\",\n  \"monto\": 50.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            },
            "description": "Enviar 2 veces con la misma Idempotency-Key. La segunda debe responder 409 Conflict."
          }
        },
        {
          "name": "[RS-07] Refresh Token Reuse Detection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "1. Hacer login. 2. Usar refresh_token (funciona). 3. Usar EL MISMO refresh_token otra vez. Debe dar 401 - 'Token reuse detected'"
          }
        },
        {
          "name": "[RS-08] Rate Limit - 6 failed logins",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"WrongPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Enviar 6 veces seguidas rápido. Las primeras 5 dan 401, la 6ta debe dar 429 (rate limit) o 423 (account blocked)."
          }
        },
        {
          "name": "[RS-04] SQL Injection attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"' OR 1=1 --\",\n  \"password\": \"test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Debe responder 401 o 422. El ORM escapa la inyección SQL."
          }
        },
        {
          "name": "[RS-06] Invalid Origin (CORS test)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Origin", "value": "https://evil-site.com" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "Con Origin malicioso, CORS debe bloquear la respuesta."
          }
        },
        {
          "name": "[RS-03] Check sensitive data not exposed",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "La respuesta NUNCA debe contener password, mfa_secret ni refresh_token."
          }
        }
      ]
    }
  ]
}
