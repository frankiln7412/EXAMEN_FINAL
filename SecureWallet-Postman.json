{
  "info": {
    "name": "SecureWallet API",
    "description": "Colección de endpoints para SecureWallet - Examen Final INF781",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "ticket",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar (RF-01)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Usuario\",\n  \"ci\": \"55555555\",\n  \"email\": \"nuevo@test.com\",\n  \"phone\": \"70555555\",\n  \"password\": \"MiPassword1!\",\n  \"captcha_token\": \"test-captcha\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Iniciar Sesión - Juan Pérez (RF-02)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "  pm.collectionVariables.set('token', jsonData.access_token);",
                  "  pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
                  "}",
                  "if (jsonData.ticket) {",
                  "  pm.collectionVariables.set('ticket', jsonData.ticket);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"User1234!@\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Iniciar Sesión - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@securewallet.com\",\n  \"password\": \"Admin123!@#\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Iniciar Sesión - María López",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria@test.com\",\n  \"password\": \"User1234!@\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Habilitar MFA (RF-03)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/mfa/enable",
              "host": ["{{base_url}}"],
              "path": ["auth", "mfa", "enable"]
            }
          }
        },
        {
          "name": "Verificar MFA",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket\": \"{{ticket}}\",\n  \"totp_code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/mfa/verify",
              "host": ["{{base_url}}"],
              "path": ["auth", "mfa", "verify"]
            }
          }
        },
        {
          "name": "Renovar Token (Refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Cerrar Sesión (RF-10)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Perfil y Billetera",
      "item": [
        {
          "name": "Ver Perfil (RF-04)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            }
          }
        },
        {
          "name": "Ver Saldo (RF-04)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet",
              "host": ["{{base_url}}"],
              "path": ["wallet"]
            }
          }
        },
        {
          "name": "Recargar Saldo (RF-05)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/wallet/topup",
              "host": ["{{base_url}}"],
              "path": ["wallet", "topup"]
            }
          }
        }
      ]
    },
    {
      "name": "Transferencias",
      "item": [
        {
          "name": "Crear Transferencia (RF-06)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": \"maria@test.com\",\n  \"monto\": 100.00,\n  \"descripcion\": \"Pago almuerzo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            }
          }
        },
        {
          "name": "Confirmar Transferencia (RF-07)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/transfers/REEMPLAZAR_CON_UUID/confirm",
              "host": ["{{base_url}}"],
              "path": ["transfers", "REEMPLAZAR_CON_UUID", "confirm"]
            }
          }
        },
        {
          "name": "Crear Transferencia +500 (Requiere TOTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": \"maria@test.com\",\n  \"monto\": 600.00,\n  \"descripcion\": \"Pago grande\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            }
          }
        }
      ]
    },
    {
      "name": "Transacciones",
      "item": [
        {
          "name": "Ver Historial (RF-08)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transactions?page=1",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Ver Historial - Filtrado por tipo (RF-08)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transactions?page=1&type=topup",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "type", "value": "topup" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (RF-09)",
      "item": [
        {
          "name": "Listar Usuarios (Solo Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            }
          }
        },
        {
          "name": "Bloquear/Desbloquear Usuario (Solo Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/REEMPLAZAR_CON_UUID/block",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "REEMPLAZAR_CON_UUID", "block"]
            }
          }
        },
        {
          "name": "Ver Bitácora de Auditoría (RS-09)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/audit-logs?page=1",
              "host": ["{{base_url}}"],
              "path": ["admin", "audit-logs"],
              "query": [
                { "key": "page", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Pruebas de Seguridad",
      "item": [
        {
          "name": "[RS-01] IDOR - Acceder a billetera de otro usuario",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet",
              "host": ["{{base_url}}"],
              "path": ["wallet"]
            },
            "description": "El endpoint /wallet siempre devuelve los datos del usuario autenticado. No se puede acceder a datos de otro usuario aunque se intente manipular la URL."
          }
        },
        {
          "name": "[RS-02] RBAC - Usuario normal accede a Admin",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            },
            "description": "Con token de usuario normal (USER), debe responder 403 Forbidden"
          }
        },
        {
          "name": "[RS-03] Datos sensibles no expuestos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "La respuesta NUNCA debe contener password, mfa_secret ni refresh_token. Verificar en BD que contraseñas están hasheadas con bcrypt (costo >= 12)."
          }
        },
        {
          "name": "[RS-04] Inyección SQL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"' OR 1=1 --\",\n  \"password\": \"test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Debe responder 401 o 422. El ORM escapa la inyección SQL automáticamente."
          }
        },
        {
          "name": "[RS-05] Idempotencia - Doble cobro",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "TEST-DOUBLE-CHARGE-KEY" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": \"maria@test.com\",\n  \"monto\": 50.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            },
            "description": "Enviar 2 veces con la misma Idempotency-Key. La segunda debe responder 409 Conflict - 'This request has already been processed'."
          }
        },
        {
          "name": "[RS-06] CORS - Origen no válido",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Origin", "value": "https://evil-site.com" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "Con Origin malicioso, CORS debe bloquear la respuesta. Solo permite http://localhost:5173."
          }
        },
        {
          "name": "[RS-07] Reutilización de Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "1. Hacer login. 2. Usar refresh_token (funciona). 3. Usar EL MISMO refresh_token otra vez. Debe dar 401 - 'Token reuse detected. All tokens revoked.'"
          }
        },
        {
          "name": "[RS-08] Rate Limit - 6 intentos fallidos",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"WrongPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Enviar 6 veces seguidas rápido. Las primeras 5 dan 401, la 6ta debe dar 429 (rate limit) o 423 (account blocked)."
          }
        },
        {
          "name": "[RS-10] XSS/CSRF (Frontend)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "El frontend React escapa todo el output automáticamente (XSS). Los tokens se manejan por header Authorization: Bearer, no por cookies (CSRF)."
          }
        }
      ]
    }
  ]
}